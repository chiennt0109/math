<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/silver_bg"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Tiêu đề lớp học -->
    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📘 Chủ đề"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/silver_text_primary"
        android:layout_marginBottom="12dp" />

    <!-- Gợi ý độ khó hiện tại -->
    <TextView
        android:id="@+id/tvDifficultyInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔹 Độ khó hiện tại: Trung bình"
        android:textSize="18sp"
        android:textColor="@color/silver_text_secondary"
        android:layout_marginBottom="16dp" />


    <Button
        android:id="@+id/btnStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📊 Xem thống kê"
        android:backgroundTint="@color/silver_button"
        android:textColor="@color/white"
        android:layout_marginBottom="10dp" />

    <!-- Danh sách chủ đề -->
    <ListView
        android:id="@+id/lvTopics"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/silver_surface"
        android:dividerHeight="1dp"
        android:background="@color/white"
        android:padding="8dp"
        android:elevation="2dp" />

</LinearLayout>
