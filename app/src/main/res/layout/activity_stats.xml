<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/silver_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📊 Thống kê học tập"
        android:textStyle="bold"
        android:textSize="24sp"
        android:textColor="@color/silver_text_primary"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvCurrentStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="@color/silver_text_primary"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvCounts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="@color/silver_text_secondary" />

</LinearLayout>
