<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- 🌈 Chủ đề chính cho ứng dụng học Toán -->
    <style name="Theme.Math" parent="Theme.Material3.Light.NoActionBar">
        <!-- Màu nền & màu chính -->
        <item name="colorPrimary">#1976D2</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#BBDEFB</item>
        <item name="colorSecondary">#64B5F6</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSurface">#FAFAFA</item>
        <item name="colorOnSurface">#212121</item>

        <!-- Màu thanh trạng thái và thanh điều hướng -->
        <item name="android:statusBarColor">?attr/colorPrimary</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>

        <!-- Font & hiển thị chữ: bỏ font tùy chỉnh -->
        <item name="android:textColor">#212121</item>
        <item name="android:windowBackground">#FAFAFA</item>

        <!-- Bo góc và nhấn -->
        <item name="android:colorControlHighlight">#90CAF9</item>
        <item name="android:colorAccent">#42A5F5</item>
        <item name="android:buttonStyle">@style/MathButtonStyle</item>
    </style>

    <!-- 💠 Style cho Toolbar -->
    <style name="MathToolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">?attr/colorPrimary</item>
        <item name="android:titleTextColor">#FFFFFF</item>
        <item name="android:subtitleTextColor">#E3F2FD</item>
        <item name="titleTextAppearance">@style/MathToolbarTitle</item>
    </style>

    <!-- 💠 Style chữ trong Toolbar -->
    <style name="MathToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 💠 Style cho các nút -->
    <style name="MathButtonStyle" parent="Widget.Material3.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:backgroundTint">#42A5F5</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

</resources>
